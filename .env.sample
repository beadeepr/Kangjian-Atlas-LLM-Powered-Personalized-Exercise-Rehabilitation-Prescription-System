# DeepSeek API 配置（火山引擎）
APP_ENV=development
DEMO_MODE=false
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500
DATABASE_URL=sqlite:///backend/database.db
REDIS_URL=
CACHE_TTL_SECONDS=300
OBJECT_STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=backend/uploads
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=kangjian-atlas
MINIO_SECURE=false
DeepSeek_API_KEY=<your api key>
DeepSeek_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DeepSeek_MODEL_ID=your model id
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRE_SECONDS=604800
ADMIN_ACCOUNTS=admin
DOCTOR_ACCOUNTS=doctor

# RAG / vector database
# auto: prefer Chroma, then Qdrant, then local JSON fallback
# chroma: require chromadb and persist locally
# qdrant: require qdrant-client; use QDRANT_URL for server mode, or QDRANT_PATH for local mode
# local: deterministic local JSON vector index for demos/tests
RAG_VECTOR_PROVIDER=auto
CHROMA_PERSIST_DIR=knowledge/rag_store/chroma
CHROMA_COLLECTION=kangjian_rehab_knowledge
QDRANT_URL=
QDRANT_PATH=knowledge/rag_store/qdrant
QDRANT_COLLECTION=kangjian_rehab_knowledge

# RTMPose / real-time pose streaming
RTMPOSE_MODEL_PATH=models/best.onnx
RTMPOSE_INPUT_SIZE=256,192
RTMPOSE_PROVIDERS=CPUExecutionProvider
POSE_BATCH_MAX_SIZE=30

# Production storage stack example for docker-compose:
# DATABASE_URL=postgresql+psycopg://kangjian:kangjian_password@postgres:5432/kangjian_atlas
# REDIS_URL=redis://redis:6379/0
# OBJECT_STORAGE_BACKEND=minio
# MINIO_ENDPOINT=minio:9000
